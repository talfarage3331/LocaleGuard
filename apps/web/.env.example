# Postgres (Neon or any managed Postgres)
DATABASE_URL=postgres://user:pass@host/localeguard

# Auth.js — GitHub OAuth app (no passwords stored)
AUTH_SECRET=generate-with-`npx auth secret`
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=

# App URL (used for Stripe Checkout success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing — Stripe (card entry stays on Stripe's hosted Checkout; we store references only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
