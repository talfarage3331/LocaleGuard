# Postgres — Supabase connection string (Project Settings → Database → Connect)
# Use the SESSION pooler / direct connection (port 5432): works for both drizzle-kit
# migrations and app runtime. The transaction pooler (port 6543) also works for the app
# because we set prepare:false, but drizzle-kit migrations require session/direct.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Auth.js — GitHub OAuth app (no passwords stored)
AUTH_SECRET=generate-with-`npx auth secret`
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=

# App URL (used for Stripe Checkout success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing — Stripe (card entry stays on Stripe's hosted Checkout; we store references only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
