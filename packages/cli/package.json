      "import": "./dist/run.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@localeguard/core": "workspace:*",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0"
