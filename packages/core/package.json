{
  "name": "@localeguard/core",
  "version": "0.0.0",
  "description": "The LocaleGuard engine: parsers, rules, reporters for i18n catalog checks.",
  "license": "MIT",
  "author": "LocaleGuard",
  "homepage": "https://github.com/talfarage3331/LocaleGuard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talfarage3331/LocaleGuard.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/talfarage3331/LocaleGuard/issues"
  },
  "keywords": [
    "i18n",
    "l10n",
    "localization",
    "internationalization",
    "icu",
    "plural",
    "cldr",
    "translation",
    "linter"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
